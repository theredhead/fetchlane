# Copy this file to `.env` and adjust the values for your local setup.
# The app loads `.env` automatically at startup.

# Path to the mounted runtime config file.
FETCHLANE_CONFIG=./fetchlane.local.json

# Optional placeholder used by the runtime config file.
# Required connection URL format:
# <engine>://<user>:<password>@<host>:<port?>/<database>
FETCHLANE_DATABASE_URL=postgres://postgres:password@127.0.0.1:5432/northwind
