@baseUrl = http://localhost:3000
@authToken =

###
# Public status snapshot
GET {{baseUrl}}/api/status

###
# Swagger UI
# If auth is enabled in runtime config, open this in a browser after authenticating.
GET {{baseUrl}}/api/docs

###
# Table names
GET {{baseUrl}}/api/data-access/table-names
Authorization: Bearer {{authToken}}

###
# Paginated table browse
GET {{baseUrl}}/api/data-access/member?pageIndex=2&pageSize=3
Authorization: Bearer {{authToken}}

###
# Table info
GET {{baseUrl}}/api/data-access/member/info
Authorization: Bearer {{authToken}}

###
# Table schema
GET {{baseUrl}}/api/data-access/member/schema
Authorization: Bearer {{authToken}}

###
# FetchRequest with positional parameters
POST {{baseUrl}}/api/data-access/fetch
Content-Type: application/json
Authorization: Bearer {{authToken}}

{
  "table": "member",
  "predicates": [
    {
      "text": "name = ? AND is_active = ?",
      "args": ["Alice", true]
    }
  ],
  "sort": [
    {
      "column": "name",
      "direction": "ASC"
    }
  ],
  "pagination": {
    "size": 10,
    "index": 0
  }
}

###
# FetchRequest with named parameters
POST {{baseUrl}}/api/data-access/fetch
Content-Type: application/json
Authorization: Bearer {{authToken}}

{
  "table": "member",
  "predicates": [
    {
      "text": "status = :status AND city = :city",
      "args": {
        "status": "open",
        "city": "Enschede"
      }
    }
  ],
  "sort": [],
  "pagination": {
    "size": 10,
    "index": 0
  }
}

###
# Validation example: should fail if fetch_max_page_size is below 5000
POST {{baseUrl}}/api/data-access/fetch
Content-Type: application/json
Authorization: Bearer {{authToken}}

{
  "table": "member",
  "predicates": [],
  "sort": [],
  "pagination": {
    "size": 5000,
    "index": 0
  }
}
