{
  "name": "fetchlane",
  "version": "0.0.1",
  "description": "Fetchlane is a multi-engine REST API for table access, schema discovery, and FetchRequest-based querying.",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "vitest run --project unit",
    "test:watch": "vitest --project unit",
    "test:cov": "vitest run --project unit --coverage",
    "test:debug": "vitest --project unit --inspect-brk --no-file-parallelism",
    "test:e2e": "vitest run --config ./vitest.e2e.config.ts",
    "test:integration": "vitest run --project integration",
    "test:integration:postgres": "vitest run --project integration integrationtests/postgres-database.spec.ts",
    "test:integration:mysql": "vitest run --project integration integrationtests/mysql-database.spec.ts",
    "test:integration:sqlserver": "vitest run --project integration integrationtests/sqlserver-database.spec.ts",
    "docs:api": "typedoc --options typedoc.json",
    "docs:api:watch": "typedoc --options typedoc.json --watch"
  },
  "dependencies": {
    "jose": "^6.1.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^11.2.6",
    "dotenv": "^17.3.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.0",
    "swagger-ui-express": "^5.0.1"
  },
  "optionalDependencies": {
    "mssql": "^11.0.1",
    "mysql2": "^3.0.0",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/supertest": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "prettier": "^3.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-loader": "^9.5.0",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^4.2.0",
    "typedoc": "^0.28.18",
    "typescript": "^5.7.0",
    "unplugin-swc": "^1.5.0",
    "vitest": "^3.0.0"
  }
}
